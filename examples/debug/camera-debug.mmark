---
canvas: 640x360
bg: #1a1a2e
debug: camera
---

@camera
  x: 0 -> 100 over 3s ease-in-out
  scale: 1 -> 1.5 over 3s ease-in-out

circle ball r:20 fill:#e94560 | 0s - 3s
  x: 320
  y: 180

rect box w:60 h:60 fill:#0f3460 | 0s - 3s
  x: 150
  y: 150

rect box2 w:60 h:60 fill:#16213e | 0s - 3s
  x: 490
  y: 200
