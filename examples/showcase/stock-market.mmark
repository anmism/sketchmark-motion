---
canvas: 900x600
bg: #0a0f1a
fps: 30
$green: #22c55e
$red: #ef4444
$grid: #1e293b
$text: #64748b
$accent: #3b82f6
---

= Stock Market | 0s - 10s =

rect panel w:840 h:520 fill:#0f172a cornerRadius:12 | 0s - 10s
  x: 450
  y: 310
  opacity: 0 -> 1 over 0.4s

text ticker "AAPL" font:Roboto size:32 fill:#fff weight:bold | 0.2s - 10s
  x: 100
  y: 70
  opacity: 0 -> 1 over 0.3s

text price "182.63" font:Roboto size:28 fill:$green weight:bold | 0.3s - 10s
  x: 220
  y: 70
  opacity: 0 -> 1 over 0.3s

text change "+2.47 (1.37%)" font:Roboto size:16 fill:$green | 0.4s - 10s
  x: 340
  y: 70
  opacity: 0 -> 1 over 0.3s

line gridH1 from:(60, 150) to:(840, 150) stroke:$grid strokeWidth:1 | 0.3s - 10s
  opacity: 0 -> 0.5 over 0.2s

line gridH2 from:(60, 250) to:(840, 250) stroke:$grid strokeWidth:1 | 0.35s - 10s
  opacity: 0 -> 0.5 over 0.2s

