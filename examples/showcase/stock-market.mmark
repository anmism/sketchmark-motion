path priceLine d:"M 80 380 C 120 360, 160 340, 200 320 S 280 350, 320 300 S 400 260, 440 280 S 520 320, 560 240 S 640 200, 680 220 S 760 180, 800 160" stroke:$accent strokeWidth:3 fill:none | 0.8s - 10s
  draw: 0 -> 1 over 3s ease-out

path areaFill d:"M 80 380 C 120 360, 160 340, 200 320 S 280 350, 320 300 S 400 260, 440 280 S 520 320, 560 240 S 640 200, 680 220 S 760 180, 800 160 L 800 480 L 80 480 Z" fill:linear(0, 150, 0, 480, #3b82f633, 0, #3b82f600, 1) | 0.8s - 10s
  opacity: 0 -> 1 over 3s

circle dot1 r:6 fill:$accent | 3.8s - 10s
  x: 800
  y: 160
  scale: 0 -> 1 over 0.3s ease-out
  opacity: f(t) = 0.7 + 0.3 * sin(t * 4)

