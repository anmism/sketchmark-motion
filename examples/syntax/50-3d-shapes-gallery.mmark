# 9. Wire sphere
@group sphere | 0s - 8s
  x: 630
  y: 350
  rotateX: -18deg
  rotateY: 0deg -> 360deg over 8s linear

@view sphereOutlineView parent:sphere | 0s - 8s
  normal: 0 0 1
circle sphereOutline r:46 fill:none stroke:#93c5fd strokeWidth:2 parent:sphereOutlineView | 0s - 8s
@view sphereEquatorView parent:sphere | 0s - 8s
  normal: 0 1 0
  up: 0 0 1
circle sphereEquator r:46 fill:none stroke:#60a5fa strokeWidth:2 parent:sphereEquatorView | 0s - 8s
@view sphereMeridianAView parent:sphere | 0s - 8s
  normal: 1 0 0
circle sphereMeridianA r:46 fill:none stroke:#38bdf8 strokeWidth:2 parent:sphereMeridianAView | 0s - 8s
@view sphereMeridianBView parent:sphere | 0s - 8s
  normal: 0.707 0 0.707
circle sphereMeridianB r:46 fill:none stroke:#38bdf8 strokeWidth:2 parent:sphereMeridianBView | 0s - 8s
text sphereLabel "Wire Sphere" font:Roboto size:14 fill:#cbd5e1 weight:bold | 0s - 8s
  x: 630
  y: 430

