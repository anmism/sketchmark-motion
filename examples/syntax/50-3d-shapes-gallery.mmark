  d: "M-38,30 L38,30 L0,-36 Z"
@view triBottom parent:triPrism | 0s - 8s
  at: 0 30 0
  normal: 0 1 0
  up: 0 0 1
rect triBottomFace w:70 h:76 fill:#0d9488 parent:triBottom | 0s - 8s
@view triLeft parent:triPrism | 0s - 8s
  at: -19 -3 0
  normal: -0.866 -0.5 0
rect triLeftFace w:70 h:76 fill:#2dd4bf parent:triLeft | 0s - 8s
@view triRight parent:triPrism | 0s - 8s
  at: 19 -3 0
  normal: 0.866 -0.5 0
