@view hexSide0 parent:hexPrism | 0s - 8s
  at: 24 14 0
  normal: 0.866 0.5 0
rect hexSideFace0 w:64 h:32 fill:#65a30d parent:hexSide0 | 0s - 8s
@view hexSide1 parent:hexPrism | 0s - 8s
  at: 0 28 0
  normal: 0 1 0
rect hexSideFace1 w:64 h:32 fill:#4d7c0f parent:hexSide1 | 0s - 8s
@view hexSide2 parent:hexPrism | 0s - 8s
  at: -24 14 0
  normal: -0.866 0.5 0
rect hexSideFace2 w:64 h:32 fill:#3f6212 parent:hexSide2 | 0s - 8s
@view hexSide3 parent:hexPrism | 0s - 8s
  at: -24 -14 0
  normal: -0.866 -0.5 0
rect hexSideFace3 w:64 h:32 fill:#365314 parent:hexSide3 | 0s - 8s
@view hexSide4 parent:hexPrism | 0s - 8s
  at: 0 -28 0
  normal: 0 -1 0
rect hexSideFace4 w:64 h:32 fill:#4d7c0f parent:hexSide4 | 0s - 8s
@view hexSide5 parent:hexPrism | 0s - 8s
