@view cylinderTop parent:cylinder | 0s - 8s
  at: 0 -42 0
  normal: 0 -1 0
  up: 0 0 -1
circle cylinderTopFace r:42 fill:#7dd3fc stroke:#bae6fd strokeWidth:2 parent:cylinderTop | 0s - 8s
text cylinderLabel "Cylinder" font:Roboto size:14 fill:#cbd5e1 weight:bold | 0s - 8s
  x: 450
  y: 225

