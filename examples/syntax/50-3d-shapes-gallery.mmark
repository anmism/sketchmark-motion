# 5. Triangular prism
@group triPrism | 0s - 8s
  x: 810
  y: 145
  rotateX: -16deg
  rotateY: 0deg -> 360deg over 8s linear

@view triFront parent:triPrism | 0s - 8s
  at: 0 0 35
  normal: 0 0 1
