text triPrismLabel "Tri Prism" font:Roboto size:14 fill:#cbd5e1 weight:bold | 0s - 8s
  x: 810
  y: 225

# 6. Hexagonal prism
@group hexPrism | 0s - 8s
  x: 90
  y: 350
  rotateX: -16deg
  rotateY: 0deg -> 360deg over 8s linear

@view hexFrontView parent:hexPrism | 0s - 8s
  at: 0 0 32
  normal: 0 0 1
