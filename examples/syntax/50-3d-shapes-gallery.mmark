---
canvas: 900x520
bg: #090d18
fps: 60
perspective: 720
vanish: 450 250
---

# 2.5D @view Shape Gallery
# Ten 3D-style forms built from oriented view planes.

# 1. Cube
@group cube | 0s - 8s
  x: 90
  y: 145
  rotateX: -18deg
  rotateY: 0deg -> 360deg over 8s linear

@view cubeFront parent:cube | 0s - 8s
  at: 0 0 27
  normal: 0 0 1
rect cubeFrontFace w:54 h:54 fill:#3b82f6 parent:cubeFront | 0s - 8s
@view cubeBack parent:cube | 0s - 8s
  at: 0 0 -27
  normal: 0 0 -1
rect cubeBackFace w:54 h:54 fill:#1e3a8a parent:cubeBack | 0s - 8s
@view cubeRight parent:cube | 0s - 8s
  at: 27 0 0
  normal: 1 0 0
rect cubeRightFace w:54 h:54 fill:#0891b2 parent:cubeRight | 0s - 8s
@view cubeLeft parent:cube | 0s - 8s
  at: -27 0 0
  normal: -1 0 0
rect cubeLeftFace w:54 h:54 fill:#22d3ee parent:cubeLeft | 0s - 8s
@view cubeTop parent:cube | 0s - 8s
  at: 0 -27 0
  normal: 0 -1 0
  up: 0 0 -1
rect cubeTopFace w:54 h:54 fill:#a855f7 parent:cubeTop | 0s - 8s
@view cubeBottom parent:cube | 0s - 8s
  at: 0 27 0
  normal: 0 1 0
  up: 0 0 1
rect cubeBottomFace w:54 h:54 fill:#6d28d9 parent:cubeBottom | 0s - 8s
text cubeLabel "Cube" font:Roboto size:14 fill:#cbd5e1 weight:bold | 0s - 8s
  x: 90
  y: 225

# 2. Pyramid
@group pyramid | 0s - 8s
  x: 270
  y: 145
  rotateX: -18deg
  rotateY: 0deg -> 360deg over 8s linear

@view pyramidBase parent:pyramid | 0s - 8s
  at: 0 35 0
  normal: 0 1 0
  up: 0 0 1
rect pyramidBaseFace w:70 h:70 fill:#475569 parent:pyramidBase | 0s - 8s
@view pyramidFront parent:pyramid | 0s - 8s
  at: 0 11.7 23.3
  normal: 0 -0.447 0.894
path pyramidFrontFace fill:#ef4444 parent:pyramidFront | 0s - 8s
  d: "M-35,26.1 L35,26.1 L0,-52.2 Z"
@view pyramidBack parent:pyramid | 0s - 8s
  at: 0 11.7 -23.3
  normal: 0 -0.447 -0.894
path pyramidBackFace fill:#3b82f6 parent:pyramidBack | 0s - 8s
  d: "M-35,26.1 L35,26.1 L0,-52.2 Z"
@view pyramidRight parent:pyramid | 0s - 8s
  at: 23.3 11.7 0
  normal: 0.894 -0.447 0
path pyramidRightFace fill:#22c55e parent:pyramidRight | 0s - 8s
  d: "M-35,26.1 L35,26.1 L0,-52.2 Z"
@view pyramidLeft parent:pyramid | 0s - 8s
  at: -23.3 11.7 0
  normal: -0.894 -0.447 0
path pyramidLeftFace fill:#f59e0b parent:pyramidLeft | 0s - 8s
  d: "M-35,26.1 L35,26.1 L0,-52.2 Z"
text pyramidLabel "Pyramid" font:Roboto size:14 fill:#cbd5e1 weight:bold | 0s - 8s
  x: 270
  y: 225

