{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://motionmark.dev/schema/scene.schema.json",
  "title": "MotionMark Scene IR",
  "type": "object",
  "additionalProperties": false,
  "required": ["version", "canvas", "duration", "elements"],
  "properties": {
    "version": { "const": 1 },
    "canvas": {
      "type": "object",
      "additionalProperties": false,
      "required": ["width", "height", "bg", "fps"],
      "properties": {
        "width": { "type": "integer", "minimum": 1 },
        "height": { "type": "integer", "minimum": 1 },
        "bg": { "type": "string" },
        "fps": { "type": "integer", "minimum": 1 },
        "perspective": { "type": "number", "exclusiveMinimum": 0 },
        "vanishX": { "type": "number" },
        "vanishY": { "type": "number" }
      }
    },
    "duration": { "type": "integer", "minimum": 0 },
    "elements": {
      "type": "array",
      "items": { "$ref": "#/$defs/element" }
    }
  },
  "$defs": {
    "element": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "type", "lifetime", "static", "animated", "comp", "anchor", "origin", "mask", "zIndex", "parent"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "type": { "enum": ["rect", "circle", "ellipse", "text", "line", "line3d", "path", "poly3d", "path3d", "plane", "cuboid", "sphere", "cylinder", "cone", "pyramid", "prism", "torus", "image", "group", "view"] },
        "lifetime": {
          "type": "object",
          "additionalProperties": false,
          "required": ["start", "end"],
          "properties": {
            "start": { "type": "integer", "minimum": 0 },
            "end": { "type": "integer", "minimum": 0 }
          }
        },
        "static": {
          "type": "object",
          "additionalProperties": {
            "anyOf": [
              { "type": "number" },
              { "type": "string" },
              { "type": "boolean" },
              {
                "type": "array",
                "items": {
                  "anyOf": [{ "type": "number" }, { "type": "string" }]
                }
              }
            ]
          }
        },
        "animated": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/animatedProperty" }
        },
        "comp": { "type": "string" },
        "anchor": {
          "enum": [
            "center",
            "top-left",
            "top-center",
            "top-right",
            "center-left",
            "center-right",
            "bottom-left",
            "bottom-center",
            "bottom-right"
          ]
        },
        "origin": {
          "enum": [
            "center",
            "top-left",
            "top-center",
            "top-right",
            "center-left",
            "center-right",
            "bottom-left",
            "bottom-center",
            "bottom-right"
          ]
        },
        "mask": {
          "anyOf": [
            { "type": "null" },
            {
              "type": "object",
              "additionalProperties": false,
              "required": ["type", "x", "y", "w", "h"],
              "properties": {
                "type": { "const": "rect" },
                "x": { "type": "number" },
                "y": { "type": "number" },
                "w": { "type": "number" },
                "h": { "type": "number" },
                "invert": { "type": "boolean" }
              }
            }
          ]
        },
        "zIndex": { "type": "number" },
        "parent": {
          "anyOf": [{ "type": "string", "minLength": 1 }, { "type": "null" }]
        }
      }
    },
    "animatedProperty": {
      "oneOf": [
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "fn"],
          "properties": {
            "type": { "const": "expression" },
            "fn": { "type": "string", "minLength": 1 }
          }
        },
        {
          "type": "object",
          "additionalProperties": false,
          "required": ["type", "points"],
          "properties": {
            "type": { "const": "keyframes" },
            "points": {
              "type": "array",
              "minItems": 1,
              "items": {
                "type": "object",
                "additionalProperties": false,
                "required": ["t", "value", "easing"],
                "properties": {
                  "t": { "type": "integer", "minimum": 0 },
                  "value": { "type": "number" },
                  "easing": { "type": "string" }
                }
              }
            }
          }
        }
      ]
    }
  }
}
